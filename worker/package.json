{
  "name": "rede-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create rede",
    "db:migrate": "wrangler d1 execute rede --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute rede --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^25.9.3",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9",
    "wrangler": "^3.80.0"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "better-auth": "^1.6.11",
    "kysely": "^0.28.17",
    "kysely-d1": "^0.4.0",
    "stripe": "^17.0.0",
    "worker-mailer": "^1.2.1"
  }
}
